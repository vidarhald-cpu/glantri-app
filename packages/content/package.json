{
  "name": "@glantri/content",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./equipment": {
      "types": "./dist/equipment/index.d.ts",
      "default": "./dist/equipment/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node -e \"require('fs').cpSync('src/data', 'dist/data', { recursive: true })\"",
    "generate:json": "tsx ./scripts/generateJson.ts",
    "export:skill-system-ai": "pnpm exec tsx ./scripts/exportSkillSystemForAi.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@glantri/domain": "workspace:*",
    "@glantri/shared": "workspace:*",
    "zod": "^3.24.2"
  }
}
