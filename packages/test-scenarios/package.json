{
  "name": "@glantri/test-scenarios",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./equipment/sampleCharacterEquipment": {
      "types": "./dist/equipment/sampleCharacterEquipment.d.ts",
      "default": "./dist/equipment/sampleCharacterEquipment.js"
    },
    "./equipment/sampleWeapons": {
      "types": "./dist/equipment/sampleWeapons.d.ts",
      "default": "./dist/equipment/sampleWeapons.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@glantri/content": "workspace:*",
    "@glantri/domain": "workspace:*",
    "@glantri/rules-engine": "workspace:*"
  }
}
