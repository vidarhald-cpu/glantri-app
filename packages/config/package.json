{
  "name": "@glantri/config",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.ts",
    "./eslint": "./eslint.base.cjs",
    "./prettier": "./prettier.base.cjs",
    "./tsconfig": "./tsconfig.package.json",
    "./vitest": "./vitest.base.ts"
  },
  "scripts": {
    "build": "mkdir -p dist && cp eslint.base.cjs prettier.base.cjs vitest.base.ts tsconfig.package.json dist/",
    "typecheck": "tsc -p tsconfig.package.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "typescript": "^5.8.0",
    "vitest": "^2.1.0"
  }
}
