generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum EquipmentCategory {
  weapon
  shield
  armor
  gear
  valuables
}

enum CarryMode {
  equipped
  on_person
  backpack
  mount
  stored
}

enum StorageLocationType {
  equipped_system
  person_system
  backpack_system
  mount_system
  home
  camp
  boat
  wagon
  cache
  building
  other
}

enum LocationAvailabilityClass {
  with_you
  elsewhere
}

enum MaterialType {
  steel
  bronze
  wood
  leather
  cloth
  bone
  stone
  silver
  gold
  other
}

enum QualityType {
  standard
  extraordinary
}

enum SpecificityType {
  generic
  specific
}

enum ItemConditionState {
  intact
  worn
  damaged
  broken
  lost
}

enum CampaignStatus {
  draft
  active
  archived
}

enum ScenarioKind {
  combat
  social
  travel
  mixed
}

enum ScenarioStatus {
  draft
  prepared
  live
  completed
  archived
}

enum ScenarioCombatStatus {
  not_started
  in_progress
  paused
  ended
}

enum ScenarioParticipantSourceType {
  character
  entity
}

enum ScenarioParticipantRole {
  player_character
  npc
  monster
  animal
  neutral
  ally
  enemy
}

enum ScenarioParticipantJoinSource {
  gm_added
  player_joined
  imported_from_template
}

enum ScenarioVisibility {
  hidden
  visible_to_all
  gm_only
}

enum CampaignAssetType {
  map
  image
  document
  handout
  drawing
}

enum ReusableEntityKind {
  npc
  monster
  animal
}

model Character {
  id               String                    @id @default(cuid())
  name             String
  level            Int                       @default(1)
  build            Json
  ownerId          String?
  createdAt        DateTime                  @default(now())
  updatedAt        DateTime                  @updatedAt
  owner            User?                     @relation(fields: [ownerId], references: [id])
  equipmentItems   CharacterEquipmentItem[]
  storageLocations CharacterStorageLocation[]
  loadouts         CharacterLoadout[]
  scenarioParticipants ScenarioParticipant[]
}

model Weapon {
  id        String   @id @default(cuid())
  name      String
  baseOb    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Encounter {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  displayName String?
  passwordHash String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  campaigns   Campaign[]
  characters  Character[]
  createdAssets CampaignAsset[]
  controlledScenarioParticipants ScenarioParticipant[] @relation("ScenarioParticipantController")
  reusableEntities ReusableEntity[]
  roles       UserRole[]
  scenarioEvents ScenarioEventLog[]
  sessions    Session[]
}

model Role {
  id        String     @id @default(cuid())
  name      String     @unique
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     UserRole[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CanonicalContentSnapshot {
  key       String   @id
  content   Json
  revision  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CharacterEquipmentItem {
  id                    String             @id
  characterId           String
  templateId            String
  category              EquipmentCategory
  displayName           String?
  specificityType       SpecificityType
  quantity              Int
  isStackable           Boolean
  material              MaterialType
  quality               QualityType
  locationId            String
  carryMode             CarryMode
  previousLocationId    String?
  previousCarryMode     CarryMode?
  conditionState        ItemConditionState
  durabilityCurrent     Int?
  durabilityMax         Int?
  encumbranceOverride   Float?
  valueOverride         Float?
  specialPropertiesJson Json?
  notes                 String?
  isEquipped            Boolean?
  isFavorite            Boolean?
  acquiredFrom          String?
  statusTagsJson        Json?
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  character             Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([characterId, locationId])
}

model CharacterStorageLocation {
  id                      String              @id
  characterId             String
  name                    String
  type                    StorageLocationType
  availabilityClass       LocationAvailabilityClass
  parentLocationId        String?
  isMobile                Boolean
  isAccessibleInEncounter Boolean
  notes                   String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  character               Character           @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@unique([characterId, name])
}

model CharacterLoadout {
  id                        String      @id
  characterId               String
  name                      String
  isActive                  Boolean
  wornArmorItemId           String?
  readyShieldItemId         String?
  activePrimaryWeaponItemId String?
  activeSecondaryWeaponItemId String?
  activeMissileWeaponItemId String?
  activeAmmoItemIds         String[]
  quickAccessItemIdsJson    Json
  notes                     String?
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt
  character                 Character   @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([characterId, isActive])
}

model Campaign {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  description String
  gmUserId    String
  status      CampaignStatus
  settingsJson Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  assets      CampaignAsset[]
  gmUser      User            @relation(fields: [gmUserId], references: [id], onDelete: Cascade)
  scenarios   Scenario[]
}

model Scenario {
  id            String             @id @default(cuid())
  campaignId    String
  name          String
  description   String
  kind          ScenarioKind
  status        ScenarioStatus
  mapAssetId    String?
  liveStateJson Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  campaign      Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  eventLogs     ScenarioEventLog[]
  mapAsset      CampaignAsset?     @relation("ScenarioMapAsset", fields: [mapAssetId], references: [id], onDelete: SetNull)
  participants  ScenarioParticipant[]

  @@index([campaignId])
  @@index([campaignId, status])
}

model ReusableEntity {
  id          String             @id @default(cuid())
  gmUserId    String
  name        String
  kind        ReusableEntityKind
  description String?
  notes       String?
  snapshotJson Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  gmUser      User               @relation(fields: [gmUserId], references: [id], onDelete: Cascade)
  scenarioParticipants ScenarioParticipant[]

  @@index([gmUserId])
}

model ScenarioParticipant {
  id          String                        @id @default(cuid())
  scenarioId  String
  sourceType  ScenarioParticipantSourceType
  characterId String?
  entityId    String?
  role        ScenarioParticipantRole
  controlledByUserId String?
  factionId   String?
  tacticalGroupId String?
  roleTag     String?
  displayOrder Int?
  joinSource  ScenarioParticipantJoinSource
  initiativeSlot Int?
  positionJson Json?
  visibilityOverridesJson Json?
  stateJson   Json
  snapshotJson Json
  isActive    Boolean                       @default(true)
  createdAt   DateTime                      @default(now())
  updatedAt   DateTime                      @updatedAt
  character   Character?                    @relation(fields: [characterId], references: [id], onDelete: SetNull)
  controlledByUser User?                    @relation("ScenarioParticipantController", fields: [controlledByUserId], references: [id], onDelete: SetNull)
  entity      ReusableEntity?               @relation(fields: [entityId], references: [id], onDelete: SetNull)
  scenario    Scenario                      @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  eventLogs   ScenarioEventLog[]

  @@index([scenarioId])
  @@index([characterId])
  @@index([entityId])
  @@index([controlledByUserId])
  @@index([scenarioId, controlledByUserId])
  @@index([scenarioId, factionId])
  @@index([scenarioId, tacticalGroupId])
}

model CampaignAsset {
  id          String             @id @default(cuid())
  campaignId  String
  type        CampaignAssetType
  title       String
  description String?
  storageUrl  String
  mimeType    String?
  visibility  ScenarioVisibility
  createdByUserId String
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  campaign    Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  createdByUser User             @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  mappedScenarios Scenario[]     @relation("ScenarioMapAsset")

  @@index([campaignId])
}

model ScenarioEventLog {
  id            String   @id @default(cuid())
  scenarioId     String
  roundNumber    Int?
  phase          Int?
  eventType      String
  actorUserId    String?
  participantId  String?
  summary        String
  payloadJson    Json?
  createdAt      DateTime @default(now())
  actorUser      User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  participant    ScenarioParticipant? @relation(fields: [participantId], references: [id], onDelete: SetNull)
  scenario       Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)

  @@index([scenarioId])
  @@index([participantId])
  @@index([actorUserId])
}
