{
  "name": "@glantri/rules-engine",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./chargen": {
      "types": "./dist/chargen/index.d.ts",
      "default": "./dist/chargen/index.js"
    },
    "./combat": {
      "types": "./dist/combat/index.d.ts",
      "default": "./dist/combat/index.js"
    },
    "./encounters": {
      "types": "./dist/encounters/index.d.ts",
      "default": "./dist/encounters/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --coverage --passWithNoTests"
  },
  "dependencies": {
    "@glantri/content": "workspace:*",
    "@glantri/domain": "workspace:*",
    "@glantri/shared": "workspace:*"
  }
}
