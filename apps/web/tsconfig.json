{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "paths": {
      "@/*": ["./src/*"],
      "@glantri/auth": ["../../packages/auth/src/index.ts"],
      "@glantri/auth/*": ["../../packages/auth/src/*"],
      "@glantri/content": ["../../packages/content/src/index.ts"],
      "@glantri/content/*": ["../../packages/content/src/*"],
      "@glantri/database": ["../../packages/database/src/index.ts"],
      "@glantri/database/*": ["../../packages/database/src/*"],
      "@glantri/domain": ["../../packages/domain/src/index.ts"],
      "@glantri/domain/*": ["../../packages/domain/src/*"],
      "@glantri/importers/*": ["../../packages/importers/src/*"],
      "@glantri/rules-engine": ["../../packages/rules-engine/src/index.ts"],
      "@glantri/rules-engine/*": ["../../packages/rules-engine/src/*"],
      "@glantri/shared": ["../../packages/shared/src/index.ts"],
      "@glantri/shared/*": ["../../packages/shared/src/*"],
      "@glantri/test-scenarios/*": ["../../packages/test-scenarios/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "incremental": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
