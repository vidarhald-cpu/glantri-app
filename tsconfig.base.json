{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@glantri/auth/*": ["packages/auth/src/*"],
      "@glantri/content/*": ["packages/content/src/*"],
      "@glantri/domain/*": ["packages/domain/src/*"],
      "@glantri/shared/*": ["packages/shared/src/*"],
      "@glantri/schemas/*": ["packages/schemas/src/*"],
      "@glantri/rules-engine/*": ["packages/rules-engine/src/*"],
      "@glantri/database/*": ["packages/database/src/*"],
      "@glantri/importers/*": ["packages/importers/src/*"],
      "@glantri/test-scenarios/*": ["packages/test-scenarios/src/*"]
    }
  }
}
